APP_HOST=127.0.0.1
APP_PORT=8000
RESEARCH_CACHE_PATH=.cache/research_agent.sqlite3
RESEARCH_CONCURRENCY=12
RESEARCH_REQUEST_TIMEOUT_SECONDS=15
RESEARCH_SEARCH_TIMEOUT_SECONDS=12
RESEARCH_EXTRACTION_TIMEOUT_SECONDS=30
RESEARCH_ENRICHMENT_TIMEOUT_SECONDS=10
RESEARCH_SEARCH_QUERY_BUDGET=36
RESEARCH_LEAD_ENRICHMENT_LIMIT=100
RESEARCH_MAX_SEARCH_PAGES=2
RESEARCH_MAX_RESULT_URLS=1000
RESEARCH_USER_AGENT=Mozilla/5.0 (compatible; BusinessResearchAgent/0.1; +https://example.local/research-agent)
RESEARCH_RESPECT_ROBOTS=true
MONGO_URI=
MONGO_DATABASE=business_research
MONGO_COLLECTION_PREFIX=research
GOOGLE_MAPS_API_KEY=
# Optional alias also accepted by the app:
GOOGLE_PLACES_API_KEY=
GEOAPIFY_API_KEY=
GEOAPIFY_FALLBACK_API_KEY=
SERPER_API_KEY=
TAVILY_API_KEY=
LLM_API_KEY=
# OpenAI-compatible endpoint. For Gemini, use:
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# LLM_MODEL=gemini-3.5-flash
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_SUMMARY_ENABLED=true
RAG_ENABLED=true
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=mistral
OLLAMA_EMBED_MODEL=nomic-embed-text
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=120
RAG_TOP_K=6
RAG_INDEX_DIR=.rag_index
